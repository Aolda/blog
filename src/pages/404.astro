---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import { buttonVariants } from '@/components/ui/button'
import Layout from '@/layouts/Layout.astro'
import { cn } from '@/lib/utils'
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="404" />
  <Breadcrumbs items={[{ label: '???', icon: 'lucide:circle-help' }]} />

  <section class="flex flex-col items-center justify-center gap-y-4 text-center">
    <div class="max-w-md">
      <h1 class="mb-4 text-3xl font-medium">404 Page not found</h1>
      <p class="prose">요청하신 페이지를 찾을 수 없습니다.</p>
    </div>
    <Link href="/" class={cn(buttonVariants({ variant: 'outline' }), 'flex gap-x-1.5 group')}>
      <span class="transition-transform group-hover:-translate-x-1">&larr;</span> 홈으로 돌아가기
    </Link>
  </section>
</Layout>
