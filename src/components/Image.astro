---
import type { ImageMetadata } from 'astro'
import { Image as AstroImage } from 'astro:assets'

interface Props {
  src: string | ImageMetadata
  alt: string
  width?: number
  height?: number
  [key: string]: unknown
}

const { src, alt, width, height, ...props } = Astro.props as Props
---

{
  typeof src === 'string' ? (
    <AstroImage src={src} alt={alt} width={width} height={height} inferSize {...props} />
  ) : (
    <AstroImage src={src} alt={alt} width={width} height={height} {...props} />
  )
}
